{
  "name": "forevercraft",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.32.0",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.13",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter @forevercraft/backend dev",
    "dev:setup": "bun run --filter @forevercraft/backend dev:setup"
  },
  "dependencies": {
    "@forevercraft/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@forevercraft/config": "workspace:*",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.6"
}
