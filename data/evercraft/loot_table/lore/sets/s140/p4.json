                "minecraft:written_book_content": {
                  "title": "The Color of Dreams",
                  "author": "Loom Keeper",
                  "pages": [
                    [
                      {
                        "text": "Each Dream had a color only Weavers could see. Joy was golden. Courage was iron-gray. Love was the color of sunrise \u2014 impossible to name, impossible to forget.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "I am not a Weaver. But once, at dawn, holding the hand of someone I loved, I saw the color. Just for a moment. It was the color of everything I'd ever wanted and everything I'd ever been given, woven together.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "I still cannot name it. I don't think names were ever meant to hold it.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
                        "text": "[Add to Collection]",
                        "color": "green",
                        "bold": true,
                        "click_event": {
                          "action": "run_command",
                          "command": "/trigger ec.lore_add set 14004"
                        }
                      }
                    ]
                  ]
                },
                "minecraft:custom_data": {
                  "lore_piece": true,
                  "lore_uid": 14004,
                  "lore_set": 140,
                  "lore_pid": 4
                },
