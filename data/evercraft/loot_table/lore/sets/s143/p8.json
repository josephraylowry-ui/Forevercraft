                "minecraft:written_book_content": {
                  "title": "What Listened",
                  "author": "Warden's Echo",
                  "pages": [
                    [
                      {
                        "text": "I will not write what they heard from beyond the portal. Some Dreams are not meant to be shared. Some silences are not meant to be broken.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "But I will tell you this: what they heard was not hostile. It was not kind. It was simply vast \u2014 a Dream so enormous that contact with it was like a candle touching the sun.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The portal is not dangerous because what lies beyond it is evil. It is dangerous because what lies beyond it is beautiful beyond comprehension. And beauty, at that scale, is indistinguishable from annihilation.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
