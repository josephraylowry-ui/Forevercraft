                  "author": "Prophet",
                  "pages": [
                    [
                      {
                        "text": "Three worlds, torn apart since the dawn of Dreams, will one day remember they were one. This is not prophecy \u2014 it is inevitability.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "Consider water. You can separate it into ice and steam and liquid, but it remembers being one substance. It yearns to return to itself. So it is with the dimensions.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The Overworld, the Nether, the End \u2014 they are not three places. They are one place, temporarily convinced it is three.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
