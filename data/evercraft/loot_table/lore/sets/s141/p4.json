                "minecraft:written_book_content": {
                  "title": "The Silent Patron",
                  "author": "Covenant Scribe",
                  "pages": [
                    [
                      {
                        "text": "There was a fifth Patron, whose domain was Endings. It spoke only once, and what it said was: 'Even Dreams must sleep.'",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The other four Patrons feared it, though they would not admit this. Endings was patient in a way that made patience look like impatience. It simply waited, knowing that all things \u2014 even Patrons \u2014 would eventually come to it.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "It was not cruel. It was kind, in the way that winter is kind \u2014 giving the ground rest so that spring can come.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
