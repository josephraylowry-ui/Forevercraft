                "minecraft:written_book_content": {
                  "title": "The Awakening",
                  "author": "Elder Dreamer",
                  "pages": [
                    [
                      {
                        "text": "Before there were names for things, there were Dreams. The first beings to walk this world did not see stone and water \u2014 they saw possibility woven from sleep.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "They walked through a world that was still deciding what it wanted to be. Trees flickered between oak and birch. Mountains rose and fell like breathing. The world was dreaming itself into existence.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "And the Dreamers dreamed with it, their footsteps teaching the ground how to be solid.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
