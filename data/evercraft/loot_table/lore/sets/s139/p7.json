                "minecraft:written_book_content": {
                  "title": "The Sleepers",
                  "author": "Elder Dreamer",
                  "pages": [
                    [
                      {
                        "text": "Some say the First Dreamers never died. They simply fell into a Dream so deep that the world grew around them like bark around heartwood.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "There is a Dreamer sleeping beneath every mountain. Their breath is the wind. Their heartbeat is the tide. Their dreams are the seasons, cycling endlessly through creation and rest.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "When you sleep, you join them briefly. Your small dream merges with their vast one, and for a moment, you are part of the original Dream \u2014 the one that made the world.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
                        "text": "[Add to Collection]",
                        "color": "green",
                        "bold": true,
                        "click_event": {
