                "minecraft:written_book_content": {
                  "title": "The Fracture",
                  "author": "Elder Dreamer",
                  "pages": [
                    [
                      {
                        "text": "Not all Dreams were kind. When a Weaver dreamed of power without purpose, the first crack appeared. The world remembers it still \u2014 we call it the Void.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The Void is not emptiness. It is the shape of a Dream that devoured itself \u2014 purpose without end, ambition without direction, hunger without satisfaction. The End dimension floats in it like a leaf in a whirlpool.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "Every Enderman carries a fragment of that original, cracked Dream. That is why they scream when you meet their eyes \u2014 they remember what they were before the crack.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
                        "text": "[Add to Collection]",
                        "color": "green",
                        "bold": true,
                        "click_event": {
                          "action": "run_command",
                          "command": "/trigger ec.lore_add set 13905"
                        }
                      }
                    ]
                  ]
                },
