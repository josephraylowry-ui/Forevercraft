                "minecraft:written_book_content": {
                  "title": "Dream Seeds",
                  "author": "Elder Dreamer",
                  "pages": [
                    [
                      {
                        "text": "They planted their Dreams like seeds. Where joy fell, flowers grew. Where fear fell, the caves deepened. The world itself was dreaming through them.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The first forest was planted by a Dreamer who missed the sound of wind through leaves. The first ocean filled because a Dreamer wept at the beauty of the sunrise. Creation was not intentional \u2014 it was emotional.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "Every biome you walk through is a feeling that someone felt so strongly it became geography.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
