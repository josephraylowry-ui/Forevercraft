                "minecraft:written_book_content": {
                  "title": "The Weavers",
                  "author": "Elder Dreamer",
                  "pages": [
                    [
                      {
                        "text": "Among the Dreamers arose those who could shape the Dreams of others. They called themselves Weavers, and the world bent to their loom.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "The Weavers did not command. They suggested. They would hold a Dream in their hands and whisper to it: 'What if you were a mountain?' And the Dream, trusting the Weaver, would try.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "This is why mountains sometimes look like they're trying to be something else \u2014 because they are, eternally, the Dream's first uncertain attempt.",
                        "color": "dark_gray",
                        "italic": true
                      }
                    ],
                    [
                      {
                        "text": "\n\n  ",
                        "color": "white"
                      },
                      {
                        "text": "[Add to Collection]",
                        "color": "green",
                        "bold": true,
                        "click_event": {
                          "action": "run_command",
                          "command": "/trigger ec.lore_add set 13903"
                        }
                      }
                    ]
                  ]
                },
