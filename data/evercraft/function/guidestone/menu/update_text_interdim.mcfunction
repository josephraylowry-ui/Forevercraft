# Guidestone Menu — Update row text with interdimensional destination info
# Macro args from storage: name, owner, x, y, z, dim, id, uuid0, uuid1, uuid2, uuid3
# Shows: [playerhead] [dim] Name  (x, y, z) with dimension label in dark_aqua

$execute if score #gs_placing ec.gs_temp matches 0 as @e[type=text_display,tag=ec.gs_text0,distance=..5,limit=1,sort=nearest] run data modify entity @s text set value [{type:"object",object:"player",player:{id:[I;$(uuid0),$(uuid1),$(uuid2),$(uuid3)]},hat:true},{text:" [$(dim)] ",color:"dark_aqua"},{text:"$(name)",color:"light_purple"},{text:"  ($(x), $(y), $(z))",color:"gray"}]
