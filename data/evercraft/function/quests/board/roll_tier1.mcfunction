# Roll a random Tier 1 (Errand) quest — 50 quests available
# Uses random command to pick 1-50
execute store result score @s ec.quest_id_1 run random value 1..50

# Reveal the quest to the player
execute if score @s ec.quest_id_1 matches 1 run tellraw @s ["",{text:"[Quests] ",color:"gold"},{text:"Quest Revealed: ",color:"yellow"},{text:"Wheat Harvest",color:"white"},{text:" — Gather 32 Wheat",color:"gray"}]
