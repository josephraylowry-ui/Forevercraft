# Era Name Lookup — sets storage evercraft:day_counter args.era_name
# Reads #era_calc ec.var (1-25), no macro needed
# 25 RPG-themed era names, cycling every 365 in-game days

execute if score #era_calc ec.var matches 1 run data modify storage evercraft:day_counter args.era_name set value "The Age of Dawn"
execute if score #era_calc ec.var matches 2 run data modify storage evercraft:day_counter args.era_name set value "The Age of Stone"
