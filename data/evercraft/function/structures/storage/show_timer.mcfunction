# Display a single loot timer entry to the player
# Run as player. Scores available: #timer_struct, #timer_hrs, #timer_rmins, #timer_x/y/z

# Resolve structure name and display timer
# struct_id mapping: 1=Ancient City, 2=End City, 3=Trial Chambers, 4=Stronghold,
# 5=Mansion, 6=Bastion, 7=Fortress, 8=Monument, 9=Desert Pyramid, 10=Jungle Pyramid,
# 11=Shipwreck, 12=Ocean Ruin, 13=Igloo, 14=Pillager Outpost, 15=Trail Ruins,
# 16=Village, 17=Mineshaft, 18=Ruined Portal, 19=Dungeon, 20=Unknown

# Ornate tier structures
execute if score #timer_struct cf.temp matches 1 run tellraw @s [{text:"  ⊳ ",color:"gold"},{text:"Ancient City",color:"dark_aqua"},{text:" (",color:"gray"},{score:{name:"#timer_x",objective:"cf.temp"},color:"white"},{text:", ",color:"gray"},{score:{name:"#timer_y",objective:"cf.temp"},color:"white"},{text:", ",color:"gray"},{score:{name:"#timer_z",objective:"cf.temp"},color:"white"},{text:") — ",color:"gray"},{score:{name:"#timer_hrs",objective:"cf.temp"},color:"gold",bold:true},{text:"h ",color:"gold"},{score:{name:"#timer_rmins",objective:"cf.temp"},color:"gold",bold:true},{text:"m",color:"gold"}]

