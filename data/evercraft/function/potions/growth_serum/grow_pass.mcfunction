# Growth Serum - Single growth pass
# Advances all crops in a 4-block radius by 1 stage
# Order: high age → low age so each crop only advances once per pass

# Wheat (max age 7)
execute positioned ~-4 ~-1 ~-4 run fill ~0 ~0 ~0 ~8 ~2 ~8 wheat[age=7] replace wheat[age=6]
