tellraw @s ["\n",{text:"=== ",color:"dark_gray"},{text:"Tank",color:"white",bold:true},{text:" ===",color:"dark_gray"},"\n",{text:"Archetype: ",color:"gray"},{text:"Frontline defense and aggro control",color:"white"},"\n",{text:"Weapon: ",color:"gray"},{text:"Shields (mainhand)",color:"white"},"\n\n",{text:"Holding a tank shield in mainhand grants passive Resistance I. Melee hits mark mobs as Taunted, periodically teleporting them to you for aggro control. Shift+right-click activates Shield Bash (raycast forward up to 10 blocks, AoE knockback).",color:"white"},"\n\n",{text:"Strengths:",color:"green"},"\n",{text:" + Only class that forces mobs to target them",color:"green"},"\n",{text:" + Passive Resistance + blocking = extremely tanky",color:"green"},"\n",{text:" + Shield Bash doubles as a gap-closer",color:"green"},"\n",{text:"Weaknesses:",color:"red"},"\n",{text:" - Low personal DPS",color:"red"},"\n",{text:" - Bashing into crowds can be risky",color:"red"},"\n",{text:" - No auto-attack; relies on cooldowns for damage",color:"red"}]
