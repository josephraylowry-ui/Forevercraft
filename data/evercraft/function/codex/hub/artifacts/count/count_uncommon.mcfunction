# Artifact Collection — Count Uncommon discoveries
# Sets adv.temp to the number of discovered Uncommon artifacts
# Run as the player

scoreboard players set @s adv.temp 0
execute if entity @s[advancements={evercraft:artifacts/collected/anchor=true}] run scoreboard players add @s adv.temp 1
