$execute if data storage eden:settings mob_manager.misc{need_sky:"enabled"} at @s if predicate evercraft:mobs/location/can_see_sky run attribute @s scale base set $(scale)
$execute if data storage eden:settings mob_manager.misc{need_sky:"disabled"} run attribute @s scale base set $(scale)
$attribute @s max_health base set $(health)
$data modify entity @s Health set value $(health)
$attribute @s follow_range base set $(follow_range)
$attribute @s movement_speed base set $(move_speed)
$attribute @s safe_fall_distance base set $(safe_fall)
$attribute @s attack_damage base set $(attck_dmg)
$execute if data storage eden:settings mob_manager.misc{creeperfuse:"enabled"} as @s[type=creeper] run data modify entity @s Fuse set value $(fuse)
$item replace entity @s[type=vex] weapon.mainhand with $(vex_equip)