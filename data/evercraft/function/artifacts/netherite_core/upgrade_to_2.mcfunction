# Upgrade Ancient Netherite Core to Level 2

playsound minecraft:block.beacon.activate player @s ~ ~ ~ 1 0.9
playsound minecraft:ui.toast.challenge_complete player @s ~ ~ ~ 1 1.3
particle minecraft:totem_of_undying ~ ~1 ~ 0.5 0.5 0.5 0.5 75
title @s title {text:"Level 2 Unlocked!",color:"gold"}
title @s subtitle {text:"Ancient Netherite Core",color:"dark_purple",bold:true}

execute if data entity @s EnderItems[{Slot:0b,id:"minecraft:beacon",components:{"minecraft:custom_data":{ancient_netherite_core:1b,level:1}}}] run item modify entity @s enderchest.0 evercraft:netherite_core/level_2
