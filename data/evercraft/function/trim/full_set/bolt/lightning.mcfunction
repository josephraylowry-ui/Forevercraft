# Strike lightning on the nearest mob you attacked
execute at @e[type=zombie,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
execute at @e[type=skeleton,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
execute at @e[type=spider,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
execute at @e[type=creeper,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
execute at @e[type=drowned,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
execute at @e[type=husk,distance=..5,limit=1,sort=nearest] run summon lightning_bolt ~ ~ ~
