# Set the item displays to show pet heads from storage
# Each slot gets its pet data from MenuDisplay storage

# Slot 0
execute if data storage evercraft:companions MenuDisplay[0] run data modify entity @e[type=item_display,tag=Pets.Slot0,tag=Pets.MenuElement,limit=1,sort=nearest] item set from storage evercraft:companions MenuDisplay[0]

