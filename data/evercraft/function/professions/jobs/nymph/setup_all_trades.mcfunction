# ===== MASTER TRADES (Tier 4) — Netherite Block Currency =====

# Buy: 1 Netherite Block -> Ancient Tree Codex (recipe riddle book)
data modify entity @s Offers.Recipes append value {tier:4,max_uses:999999,xp:20,uses:0,priceMultiplier:0.0f,specialPrice:0,demand:0,rewardExp:1b,buy:{id:"minecraft:netherite_block",count:1},sell:{id:"minecraft:written_book",count:1,components:{"minecraft:written_book_content":{title:"Ancient Tree Codex",author:"The Nymph",pages:[{text:"\n\n    §2§lANCIENT TREE\n    CODEX§r\n\n§7§oThe roots remember\nwhat hands forget.\nHerein lie the shapes\nof creation...§r\n\n§8— The Nymph"},{text:"§2§lThe Waystone§r\n\n§7§oFour stones that\nfind what is lost,\nalternating with the\ndarkest metal's cost.\n\nA fallen star rests\nat the heart of all,\nand from this anchor\nworlds may call.§r"},{text:"§2§lColors of the Path§r\n\n§7§oA waystone shaped\nmay yet be painted.\nThe hue of sky,\nof leaves, of sunset,\nor of blood.\n\nSimply wed the stone\nto the color of\nyour choosing.\nNo table required.§r"},{text:"§2§lThe World Spinner§r\n\n§7§oThe darkest metal\nsix times placed,\ntwo wheels of time\nabove embraced.\n\nBetween them, a needle\nthat points to death.\nBelow, a frame\nof netherite breath.\n\n§8Bind it to stone\nthat pulls the lost.§r"},{text:"§2§lThe Timekeeper§r\n\n§7§oFour bars of ancient\nmetal, four faces\nthat tell the hour.\n\nA diamond shape of\ndarkness and time,\nwith a dying star\nburning at its core.\n\n§8It hears the ruins\nbreathing.§r"},{text:"§2§lThe Sleeping Giant§r\n\n§7§oEight walls of the\ndensest dark, forged\ninto solid blocks.\n\nWithin this cage\nof compressed might,\na beam of infinite\nlight waits unawoken.\n\n§8Feed it more of\nits own kind to grow.§r"},{text:"§2§lThe Dreamer's Vessel§r\n\n§7§oFour tales of wisdom\npenned by many hands,\nset like compass points\nin dark metal bands.\n\nA dying star burns\nat the crossing of lore.\n\n§8All that dreamers earn,\nthis tome may store.§r"},{text:"§2§lThe Beast's Delight§r\n\n§7§oCarrots blessed by\nMidas at each corner.\nSweet nectar above\nand below the center.\n\nBones of the earth\nflank a crystal heart.\nFour treats emerge\nfrom this culinary art.§r"},{text:"§2§lThe Binder of Souls§r\n\n§7§oA treasure from the\ndeepest sea, paired\nwith fortune's foot.\n\nCrying stone beside\na mountain's call.\nTwo by two, compact\nand small.\n\n§8A ledger for those\nwho walk beside you.§r"},{text:"§2§lThe Hearthkeeper's Spoon§r\n\n§7§oSix branches form\na frame of wood.\nA gem of ice sits\nat its root.\n\nGold warms the heart\nwhere embers meet,\nand iron's smallest\nkiss completes the feat.\n\n§8Stir the flames\nwith this in hand.§r"},{text:"§2§lThe Commander's Call§r\n\n§7§oNo table shape\nis needed here—\njust three things mixed\nwithout veneer.\n\nA mountain's cry,\nthe darkest blade,\nand the beast's delight\nyou've already made.\n\n§8Your beast will heed\nthis battle hymn.§r"},{text:"§2§lThe Dreamer's Shield§r\n\n§7§oFour blocks of the\ndarkest metal stand\nat every corner.\n\nShields form a diamond\nward between them,\nand at the heart,\na beam of gathered light.\n\n§8When struck, the dreamer\nshall not fall.§r"},{text:"§8§o\n\n\n  The tree remembers.\n\n  Craft wisely,\n  traveler.\n\n\n        §2— N§r"}]},"minecraft:custom_name":{text:"Ancient Tree Codex",color:"dark_green",italic:false},"minecraft:lore":[{text:"Secrets of forgotten crafts",color:"gray",italic:true}],"minecraft:custom_data":{evercraft_book:"ancient_tree_codex",evercraft_item:true}}}}

